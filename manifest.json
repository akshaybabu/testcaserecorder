{
  "manifest_version": 3,
  "name": "AS Web Recorder",
  "version": "2.0.0",
  "description": "Browser recorder with live step capture, replay, evidence, locator intelligence, and automation exports",
  "permissions": [
    "scripting",
    "activeTab",
    "storage",
    "tabs",
    "webRequest",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "AS Web Recorder",
    "default_icon": {
      "16": "images/icon-16.png",
      "32": "images/icon-48.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "all_frames": true
    }
  ],
  "icons": {
    "16": "images/icon-16.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  }
}
